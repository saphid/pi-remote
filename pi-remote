#!/usr/bin/env sh
set -eu
PATH="$HOME/.local/npm-global/bin:$HOME/.npm-global/bin:$HOME/.local/bin:$PATH"
export PATH
SOURCE=$0
while [ -L "$SOURCE" ]; do
  DIR=$(CDPATH='' cd -P -- "$(dirname -- "$SOURCE")" && pwd)
  TARGET=$(readlink "$SOURCE")
  case $TARGET in
    /*) SOURCE=$TARGET ;;
    *) SOURCE=$DIR/$TARGET ;;
  esac
done
DIR=$(CDPATH='' cd -P -- "$(dirname -- "$SOURCE")" && pwd)
if command -v node >/dev/null 2>&1 && [ -r "$DIR/dist/pi-remote.js" ]; then
  exec node "$DIR/dist/pi-remote.js" "$@"
fi
exec "$DIR/pi-remote.sh" "$@"
